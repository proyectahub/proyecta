# ===== PROYECTA Backend Configuration =====

# Server
PORT=3000

# ===== Monero Mining Integration =====
# Required for full mining functionality

# Monero RPC Endpoint
# Local: http://localhost:18081 (requires local monerod)
# Remote: https://node.moneroworld.com:18089
MONERO_RPC_HOST=https://node.moneroworld.com:18089

# RPC Authentication (optional if using public node)
MONERO_RPC_USER=
MONERO_RPC_PASS=

# BIP-39 Master Seed for deterministic address generation
# SECURITY: Store in Railway Secrets, NOT in version control
# Generate with: monerod --restore-deterministic-wallet
MONERO_MASTER_SEED=

# ===== ORCID OAuth =====
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:3001/api/orcid/callback
