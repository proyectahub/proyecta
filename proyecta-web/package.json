{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "preview": "vite preview",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:pages:create": "wrangler pages project create divulgaria --production-branch main",
    "cf:pages:deploy": "npm run build && wrangler pages deploy dist --project-name divulgaria --branch main",
    "cf:pages:preview": "npm run build && wrangler pages deploy dist --project-name divulgaria --branch preview-local",
    "cf:api:deploy": "wrangler deploy --config cloudflare/api-proxy/wrangler.toml",
    "cf:api:tail": "wrangler tail --config cloudflare/api-proxy/wrangler.toml",
    "cf:api:status": "powershell -ExecutionPolicy Bypass -File ./scripts/check-cloudflare-backend.ps1",
    "cf:api:refresh-tunnel": "powershell -ExecutionPolicy Bypass -File ./scripts/refresh-cloudflare-backend.ps1",
    "cf:api:reactivate": "powershell -ExecutionPolicy Bypass -File ./scripts/watch-cloudflare-backend.ps1 -RunOnce",
    "cf:api:watch": "powershell -ExecutionPolicy Bypass -File ./scripts/watch-cloudflare-backend.ps1",
    "cf:api:startup": "powershell -ExecutionPolicy Bypass -File ./scripts/install-watchdog-startup.ps1",
    "fb:create-profile": "node ./scripts/facebook-growth-automation.mjs create-profile",
    "fb:connect": "node ./scripts/facebook-growth-automation.mjs connect-url",
    "fb:accounts": "node ./scripts/facebook-growth-automation.mjs accounts",
    "fb:publish": "node ./scripts/facebook-growth-automation.mjs publish",
    "fb:boost": "node ./scripts/facebook-growth-automation.mjs boost",
    "fb:metrics": "node ./scripts/facebook-growth-automation.mjs metrics",
    "seed:simulation": "node ./scripts/seed-simulation.mjs",
    "restore:real": "node ./scripts/restore-real-state.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^5.22.0",
    "randomx.js": "^0.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0",
    "wrangler": "^4.84.1"
  }
}
